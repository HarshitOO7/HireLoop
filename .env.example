# Fast provider — cheap/fast — used for scraping + fit scoring (high volume)
AI_FAST_PROVIDER=groq
AI_FAST_API_KEY=your_groq_key_here
AI_FAST_MODEL=

# Quality provider — best model — used for resume + cover letter generation
AI_QUALITY_PROVIDER=anthropic
AI_QUALITY_API_KEY=your_anthropic_key_here
AI_QUALITY_MODEL=

# Shared settings
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.3

# Provider defaults (for reference):
# anthropic  → claude-sonnet-4-6
# openai     → gpt-4o
# gemini     → gemini-2.0-flash
# groq       → llama-3.3-70b-versatile
# ollama     → llama3.2 (local, free)

# Telegram
TELEGRAM_BOT_TOKEN=get_from_botfather
# Comma-separated list of Telegram usernames or numeric IDs allowed to use the bot
# Accepts: @username, username (without @), or numeric ID — mix freely
# Example: ALLOWED_TELEGRAM_IDS=@yourusername,@friend,123456789
# Leave blank = open to anyone (not recommended — costs your API credits)
ALLOWED_TELEGRAM_IDS=

# Optional (legacy)
SERPAPI_KEY=optional_for_google_jobs_fallback

# Database
# Local dev:      sqlite:///hireloop.db
# VPS (Docker):   sqlite:///data/hireloop.db
DATABASE_URL=sqlite:///hireloop.db

# Ollama (only needed if AI_FAST_PROVIDER=ollama or AI_QUALITY_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434

# ── Litestream — SQLite replication to OCI Object Storage ─────────────────────
# Get Access Key + Secret: OCI Console → User Settings → Tokens and keys → Customer Secret Keys
LITESTREAM_ACCESS_KEY=your_oci_access_key
LITESTREAM_SECRET_KEY=your_oci_secret_key
LITESTREAM_BUCKET=hireloop-backups
LITESTREAM_REGION=ca-toronto-1
# OCI Console → top-right avatar → Tenancy → Object Storage Namespace
OCI_NAMESPACE=your_tenancy_namespace
